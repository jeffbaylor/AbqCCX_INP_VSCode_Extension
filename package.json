{
  "name": "abaqus-inp",
  "displayName": "Abaqus Input File",
  "description": "Syntax highlighting and language support for Abaqus .inp input files",
  "version": "0.1.0",
  "publisher": "jbaylor",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "abaqus",
    "calculix",
    "ccx",
    "inp",
    "fea",
    "finite element",
    "simulation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffbaylor/AbqCCX_INP_VSCode_Extension.git"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "abaqus",
        "aliases": [
          "Abaqus Input",
          "abaqus"
        ],
        "extensions": [
          ".inp",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "calculix",
        "aliases": [
          "CalculiX Input",
          "calculix",
          "CCX"
        ],
        "extensions": [
          ".inp",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abaqus",
        "scopeName": "source.abaqus",
        "path": "./syntaxes/abaqus.tmLanguage.json"
      },
      {
        "language": "calculix",
        "scopeName": "source.abaqus",
        "path": "./syntaxes/abaqus.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.2"
  }
}
